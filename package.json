{
  "name": "catalog-update-action",
  "version": "0.10.0",
  "description": "Automated dependency updates for Bun catalog: protocol",
  "license": "MIT",
  "author": "brandhaug",
  "homepage": "https://github.com/brandhaug/catalog-update-action#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandhaug/catalog-update-action.git"
  },
  "bugs": {
    "url": "https://github.com/brandhaug/catalog-update-action/issues"
  },
  "keywords": [
    "bun",
    "catalog",
    "dependabot",
    "dependency-updates",
    "github-action",
    "monorepo",
    "workspaces"
  ],
  "type": "module",
  "bin": {
    "catalog-update": "src/main.ts"
  },
  "files": [
    "src",
    "schema.json"
  ],
  "scripts": {
    "start": "bun src/main.ts",
    "dry-run": "bun src/main.ts --dry-run",
    "test": "bun test",
    "lint": "bunx oxlint --type-aware src/",
    "fmt": "bunx oxfmt src/",
    "fmt:check": "bunx oxfmt --check src/",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  }
}
